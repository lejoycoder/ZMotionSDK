<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Color x:Key="ZMColorBg">#FF0E1623</Color>
    <Color x:Key="ZMColorPanel">#FF182235</Color>
    <Color x:Key="ZMColorPanelSoft">#FF1D2A42</Color>
    <Color x:Key="ZMColorPrimary">#FF2E7EEA</Color>
    <Color x:Key="ZMColorPrimaryLight">#FF5CA1FF</Color>
    <Color x:Key="ZMColorText">#FFE9F0FF</Color>
    <Color x:Key="ZMColorTextMuted">#FF9FB0CE</Color>
    <Color x:Key="ZMColorSuccess">#FF2E9E6F</Color>
    <Color x:Key="ZMColorWarning">#FFF0A63A</Color>
    <Color x:Key="ZMColorDanger">#FFE25555</Color>

    <SolidColorBrush x:Key="MaterialDesignPaper" Color="{StaticResource ZMColorBg}" />
    <SolidColorBrush x:Key="MaterialDesignCardBackground" Color="{StaticResource ZMColorPanel}" />
    <SolidColorBrush x:Key="MaterialDesignBody" Color="{StaticResource ZMColorText}" />
    <SolidColorBrush x:Key="MaterialDesignBodyLight" Color="{StaticResource ZMColorTextMuted}" />
    <SolidColorBrush x:Key="MaterialDesignValidationErrorBrush" Color="{StaticResource ZMColorDanger}" />
    <SolidColorBrush x:Key="ZMAccentBrush" Color="{StaticResource ZMColorPrimary}" />
    <SolidColorBrush x:Key="ZMAccentLightBrush" Color="{StaticResource ZMColorPrimaryLight}" />
    <SolidColorBrush x:Key="ZMStatusSuccessBrush" Color="{StaticResource ZMColorSuccess}" />
    <SolidColorBrush x:Key="ZMStatusSuccessSoftBrush" Color="#4438A169" />
    <SolidColorBrush x:Key="ZMStatusWarningBrush" Color="{StaticResource ZMColorWarning}" />
    <SolidColorBrush x:Key="ZMStatusWarningSoftBrush" Color="#44F0A63A" />
    <SolidColorBrush x:Key="ZMStatusDangerBrush" Color="{StaticResource ZMColorDanger}" />
    <SolidColorBrush x:Key="ZMStatusDangerSoftBrush" Color="#44E25555" />
    <SolidColorBrush x:Key="ZMStatusInfoBrush" Color="{StaticResource ZMColorPrimaryLight}" />
    <SolidColorBrush x:Key="ZMStatusInfoSoftBrush" Color="#334E8CDD" />
    <SolidColorBrush x:Key="ZMTagBrushA" Color="#FF2C9A8A" />
    <SolidColorBrush x:Key="ZMTagBrushB" Color="#FFC06A2A" />
    <SolidColorBrush x:Key="ZMTagBrushC" Color="#FF8A6ACF" />
    <SolidColorBrush x:Key="ZMTagBrushD" Color="#FF3A8FC0" />

    <FontFamily x:Key="MaterialDesignFont">Segoe UI</FontFamily>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{StaticResource MaterialDesignPaper}" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
        <Setter Property="FontFamily" Value="{StaticResource MaterialDesignFont}" />
        <Setter Property="TextElement.FontSize" Value="13" />
    </Style>

    <Style TargetType="Page">
        <Setter Property="Background" Value="{StaticResource MaterialDesignPaper}" />
    </Style>

    <Style x:Key="MaterialDesignHeadline4TextBlock" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
    </Style>

    <Style x:Key="MaterialDesignHeadline5TextBlock" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
    </Style>

    <Style x:Key="MaterialDesignHeadline6TextBlock" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
    </Style>

    <Style x:Key="MaterialDesignSubtitle1TextBlock" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
    </Style>

    <Style x:Key="MaterialDesignCaptionTextBlock" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBodyLight}" />
    </Style>

    <Style x:Key="ZMTextBoxStyle" BasedOn="{StaticResource MaterialDesignFloatingHintTextBox}" TargetType="TextBox">
        <Setter Property="Background" Value="#FF22314A" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
        <Setter Property="BorderBrush" Value="#FF3A4F70" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="34" />
    </Style>

    <Style x:Key="ZMComboBoxStyle" BasedOn="{StaticResource MaterialDesignFloatingHintComboBox}" TargetType="ComboBox">
        <Setter Property="Background" Value="#FF22314A" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
        <Setter Property="BorderBrush" Value="#FF3A4F70" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="MinHeight" Value="34" />
    </Style>

    <Style x:Key="ZMButtonBaseStyle" BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="ZMPrimaryButtonStyle" BasedOn="{StaticResource MaterialDesignRaisedButton}" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ZMAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

    <Style x:Key="ZMSecondaryButtonStyle" BasedOn="{StaticResource MaterialDesignOutlinedButton}" TargetType="Button">
        <Setter Property="Background" Value="#222B3A55" />
        <Setter Property="BorderBrush" Value="#FF4E6286" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

    <Style x:Key="ZMFlatButtonStyle" BasedOn="{StaticResource MaterialDesignFlatButton}" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

    <Style BasedOn="{StaticResource MaterialDesignDataGrid}" TargetType="DataGrid">
        <Setter Property="Background" Value="#FF1A263C" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="BorderBrush" Value="#FF304462" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="#FF213253" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style BasedOn="{StaticResource MaterialDesignDataGridCell}" TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8,6" />
    </Style>


    <Style BasedOn="{StaticResource MaterialDesignTabControl}" TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
    </Style>

    <Style BasedOn="{StaticResource MaterialDesignTabItem}" TargetType="TabItem">
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <Style TargetType="StatusBar">
        <Setter Property="Background" Value="#FF15233A" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
    </Style>

    <Style x:Key="ZMDialogHostStyle" TargetType="{x:Type materialDesign:DialogHost}">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style x:Key="ZMCardStyle" TargetType="{x:Type materialDesign:Card}">
        <Setter Property="Background" Value="{StaticResource MaterialDesignCardBackground}" />
        <Setter Property="BorderBrush" Value="#FF314766" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="ZMColorZoneStyle" TargetType="{x:Type materialDesign:ColorZone}">
        <Setter Property="Background" Value="#FF1B2D4A" />
        <Setter Property="BorderBrush" Value="#FF2D4468" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Style.Triggers>
            <Trigger Property="Mode" Value="PrimaryMid">
                <Setter Property="Background" Value="#FF1B2D4A" />
            </Trigger>
            <Trigger Property="Mode" Value="PrimaryLight">
                <Setter Property="Background" Value="#FF24395B" />
            </Trigger>
            <Trigger Property="Mode" Value="PrimaryDark">
                <Setter Property="Background" Value="#FF132038" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ZMChipStyle" TargetType="{x:Type materialDesign:Chip}">
        <Setter Property="Background" Value="#25304866" />
        <Setter Property="BorderBrush" Value="#FF496086" />
        <Setter Property="Foreground" Value="{StaticResource MaterialDesignBody}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

    <Style x:Key="NavigationButtonStyle" BasedOn="{StaticResource ZMFlatButtonStyle}" TargetType="Button">
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Margin" Value="0,0,0,6" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style x:Key="NavigationButtonActiveStyle" BasedOn="{StaticResource NavigationButtonStyle}" TargetType="Button">
        <Setter Property="Background" Value="#334F76B0" />
        <Setter Property="BorderBrush" Value="#FF5CA1FF" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
</ResourceDictionary>
