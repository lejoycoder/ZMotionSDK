<Window
    x:Class="ZMotionTest.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ZMotion 运动控制器测试工具"
    Width="1460"
    Height="920"
    Background="{DynamicResource MaterialDesignPaper}"
    FontFamily="{DynamicResource MaterialDesignFont}"
    TextElement.FontSize="13"
    TextElement.FontWeight="Regular"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <materialDesign:DialogHost Identifier="RootDialog">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <materialDesign:ColorZone
                Grid.Row="0"
                Padding="16"
                Mode="PrimaryMid"
                Style="{DynamicResource ZMColorZoneStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Foreground="White" Style="{DynamicResource MaterialDesignHeadline5TextBlock}" Text="ZMotion 运动控制器测试工具" />
                        <TextBlock Margin="0,2,0,0" Foreground="#B8CCE8" Text="现代工业监控风 · 全局统一状态与交互" />
                    </StackPanel>

                    <Border
                        Grid.Column="1"
                        Padding="10,4"
                        Background="#305CA1FF"
                        BorderBrush="#FF79B5FF"
                        BorderThickness="1"
                        CornerRadius="8">
                        <TextBlock FontWeight="SemiBold" Foreground="White" Text="{Binding CurrentPageTitle}" />
                    </Border>
                </Grid>
            </materialDesign:ColorZone>

            <Grid Grid.Row="1" Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <materialDesign:Card Grid.Column="0" Padding="16" Style="{DynamicResource ZMCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,14"
                            HorizontalAlignment="Center"
                            Style="{DynamicResource MaterialDesignHeadline6TextBlock}"
                            Text="功能导航" />

                        <Button
                            x:Name="ConnectionButton"
                            Click="NavigateToPage"
                            Content="连接管理"
                            Style="{DynamicResource NavigationButtonStyle}"
                            Tag="Connection" />

                        <Button
                            x:Name="AxisMonitorButton"
                            Click="NavigateToPage"
                            Content="轴状态监控"
                            Style="{DynamicResource NavigationButtonStyle}"
                            Tag="AxisMonitor" />

                        <Button
                            x:Name="AxisControlButton"
                            Click="NavigateToPage"
                            Content="轴运动控制"
                            Style="{DynamicResource NavigationButtonStyle}"
                            Tag="AxisControl" />

                        <Button
                            x:Name="IOControlButton"
                            Click="NavigateToPage"
                            Content="IO 控制"
                            Style="{DynamicResource NavigationButtonStyle}"
                            Tag="IOControl" />

                        <Button
                            x:Name="ParameterTestButton"
                            Click="NavigateToPage"
                            Content="参数测试"
                            Style="{DynamicResource NavigationButtonStyle}"
                            Tag="ParameterTest" />

                        <Button
                            x:Name="MotionBufferButton"
                            Click="NavigateToPage"
                            Content="运动缓存测试"
                            Style="{DynamicResource NavigationButtonStyle}"
                            Tag="MotionBuffer" />
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="2" Padding="12" Style="{DynamicResource ZMCardStyle}">
                    <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden" />
                </materialDesign:Card>
            </Grid>

            <materialDesign:ColorZone
                Grid.Row="2"
                Padding="16,8"
                Mode="PrimaryLight"
                Style="{DynamicResource ZMColorZoneStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <materialDesign:PackIcon
                            x:Name="ConnectionIcon"
                            Width="16"
                            Height="16"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Foreground="{Binding ConnectionIconColor}"
                            Kind="{Binding ConnectionIconKind}" />
                        <TextBlock
                            x:Name="ConnectionStatusText"
                            VerticalAlignment="Center"
                            FontWeight="SemiBold"
                            Foreground="{Binding ConnectionStatusColor}"
                            Text="{Binding ConnectionStatus}" />
                    </StackPanel>

                    <TextBlock
                        x:Name="StatusText"
                        Grid.Column="1"
                        Margin="16,0"
                        VerticalAlignment="Center"
                        Text="{Binding StatusText}" />

                    <TextBlock
                        x:Name="TimeText"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Text="{Binding TimeText}" />
                </Grid>
            </materialDesign:ColorZone>
        </Grid>
    </materialDesign:DialogHost>
</Window>

